# Nova Verify Frontend - Environment Variables
# Copy to .env and fill in values

# =============================================================================
# Contract Configuration
# =============================================================================
# These are auto-loaded from deploy-info.json when available.
# Set them manually here for development or as fallbacks.

# Deployed contract ID on Stellar (auto-populated by deploy-testnet.js)
REACT_APP_CONTRACT_ID=

# Admin public key for the deployed contract (Stellar address starting with G)
REACT_APP_ADMIN_PUBLIC_KEY=

# SHA-256 hash of the deployed WASM
REACT_APP_WASM_HASH=

# =============================================================================
# Stellar Network Configuration
# =============================================================================

# Network to connect to: testnet, mainnet, or futurenet
REACT_APP_STELLAR_NETWORK=testnet

# Soroban RPC URL (auto-derived from network if not set)
# REACT_APP_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API URL (auto-derived from network if not set)
# REACT_APP_HORIZON_URL=https://horizon-testnet.stellar.org

# =============================================================================
# API Configuration
# =============================================================================

# Backend API base URL
REACT_APP_API_URL=http://localhost:3001/api

# =============================================================================
# Analytics
# =============================================================================

# Google Analytics 4 measurement ID (optional)
REACT_APP_GA_ID=
